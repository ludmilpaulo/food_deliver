# Next.js Environment Variables Example

# API Configuration
NEXT_PUBLIC_BASE_API=https://kudya-api.onrender.com
# For local development (Kudya backend — www_kudya_shop):
# NEXT_PUBLIC_BASE_API=http://localhost:8000
# Note: port 8001 may be used by a different Django project without /api/auth/login/

# Google Maps API Key
NEXT_PUBLIC_GOOGLE_API_KEY=your_google_maps_api_key_here

# App URL
NEXT_PUBLIC_APP_URL=https://www.kudya.shop

# Analytics (do not hardcode tokens in source)
NEXT_PUBLIC_MIXPANEL_TOKEN=

# Error monitoring (recommended for production)
NEXT_PUBLIC_SENTRY_DSN=

